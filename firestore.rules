rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================
    // Users
    // ===========================
    match /users/{userId} {

      allow read, write: if request.auth != null
      && request.auth.uid == userId;

    }

    // ===========================
    // Trust Relationships
    // ===========================
    match /trust_relationships/{requestId} {

      allow read, write: if request.auth != null;

    }

    // ===========================
    // User Locations
    // ===========================
    match /user_locations/{uid} {

      allow read: if request.auth != null;

      allow write: if request.auth != null
      && request.auth.uid == uid;

    }

    // ===========================
    // Active SOS Sessions
    // ===========================
    match /sos_sessions/{sessionId} {

      allow read, write: if request.auth != null;

      // Responders Subcollection
      match /responders/{uid} {

        allow read, write: if request.auth != null;

      }

    }

    // ===========================
    // SOS History
    // ===========================
    match /sos_history/{sessionId} {

      allow read, write: if request.auth != null;

    }

    // ===========================
    // Notifications
    // ===========================
    match /notifications/{notificationId} {

      allow read, write: if request.auth != null;

    }

    // ===========================
    // Active Layer 2 Alerts
    // ===========================
    match /active_layer2_alerts/{alertId} {

      allow read, write: if request.auth != null;

    }

  }
}
